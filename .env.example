# SmartGuard Environment Configuration

# Gemini API Key (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Other LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard Configuration
DASHBOARD_PORT=8501

# Classifier Configuration
DEFAULT_THRESHOLD=0.3
ENABLE_LATENCY_LOGGING=true

# LLM Backend Configuration
LLM_PROVIDER=gemini  # Options: gemini, openai, anthropic
LLM_MODEL=gemini-3-flash-preview  # Gemini 3 Flash Preview (free tier)
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
